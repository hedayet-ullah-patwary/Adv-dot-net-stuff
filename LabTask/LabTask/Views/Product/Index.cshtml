@if (TempData["Msg"] != null)
{
    
    <p class="alert alert-success">@TempData["Msg"]</p>
}

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td><a href="/product/details/@item.Id">Details</a></td>
        </tr>
    }
</table>
