
<h2>Login</h2>
<form method="post">
    Email: <input type="email" name="Email" placeholder="Name" class="form-control" /> <br />
    Password: <input type="password" name="Pass" placeholder="Password" class="form-control" /> <br />
    <button type="submit">Login</button>
</form>
<p style="color:red">@ViewBag.Error</p>
<p>Create an account  <a href="/Registration/Register">Register Here</a></p>

