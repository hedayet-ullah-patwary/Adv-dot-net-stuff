@model List<NewProject.Models.Employee>

<h2>Employee List</h2>
<hr />

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Salary</th>
            <th>Designation</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td style = "
                    @if(emp.Designation == "Manager") { 
                        @:font-weight:bold; 
                    }               
                ">@emp.Name </td>
                <td style="color: @(emp.Salary > 50000 ? "green" : "black")">
                    @emp.Salary.ToString("C")
                </td>

                <td>@emp.Designation</td>
            </tr>
        }
    </tbody>
</table>

<hr />
<h4>Total Employees: @Model.Count</h4>